source 'https://gitee.com/mirrors/CocoaPods-Specs.git'

platform :ios, '12.0'
inhibit_all_warnings!
use_modular_headers!

# 设置所有Pod的部署目标版本
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
      # 修复沙盒权限问题 - 永久解决方案
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      config.build_settings['ENABLE_STRICT_OBJC_MSGSEND'] = 'NO'
      # 禁用代码签名验证
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
  
  # 修复资源复制脚本，避免沙盒权限问题
  installer.pods_project.targets.each do |target|
    target.build_phases.each do |phase|
      if phase.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
        if phase.name && phase.name.include?('Copy Pods Resources')
          # 使用更简单的脚本避免权限问题
          phase.shell_script = <<~SCRIPT
            echo "跳过 Pods 资源复制以避免沙盒权限问题"
            echo "资源将通过 Xcode 自动处理"
            exit 0
          SCRIPT
        end
      end
    end
  end
end

target 'Bunnyx' do

  pod 'AFNetworking', '~> 4.0'
  pod 'SDWebImage','5.19.2',:modular_headers => true
  pod 'Masonry'
  pod 'MJRefresh'
  pod 'ReactiveObjC'
  pod 'YYModel'
  pod 'YYCache'
  pod 'SVProgressHUD'
  pod 'IQKeyboardManager'
  pod 'FMDB'
  pod 'CocoaLumberjack/Swift' # 日志，可与 ObjC 共存
  pod 'DZNEmptyDataSet'
  pod 'TZImagePickerController',:modular_headers => true
  pod 'Toast'
  pod 'YYCategories'
  pod 'YYText'
end

target 'BunnyxTests' do
  inherit! :search_paths
end

target 'BunnyxUITests' do
  inherit! :search_paths
end